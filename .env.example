# ============================================================================
# Ahnajak Topup — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── MySQL Database ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ahnajak_topup

# ── JWT Authentication ───────────────────────────────────────────────────────
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-long-string
JWT_EXPIRES_IN=365d

# ── API Server ───────────────────────────────────────────────────────────────
PORT=3010
# Public URL of your server (used for G2Bulk callback URLs)
PUBLIC_BASE_URL=http://localhost:3010

# ── External API Keys ────────────────────────────────────────────────────────
ICON_API_KEY=
G2BULK_API_KEY=

# ── Telegram Notifications (optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=